        "\n",
        "fare['low'] = fuzz.trimf(fare.universe, [0, 0, 40])\n",
        "fare['medium'] = fuzz.trimf(fare.universe, [20, 50, 80])\n",
        "fare['high'] = fuzz.trimf(fare.universe, [60, 100, 100])\n",
        "\n",
        "rules = [\n",
